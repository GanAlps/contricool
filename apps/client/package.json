{
  "name": "@contricool/client",
  "version": "0.0.1",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "dev:web": "expo start --web",
    "build:web": "expo export -p web",
    "build:android": "eas build --profile preview --platform android --local",
    "build:android:cloud": "eas build --profile preview --platform android",
    "build:ios": "eas build --profile preview --platform ios --local",
    "build:ios:cloud": "eas build --profile preview --platform ios",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@contricool/client-sdk": "workspace:*",
    "@hookform/resolvers": "^3.9.1",
    "@sentry/react-native": "~6.10.0",
    "@tanstack/react-query": "^5.62.7",
    "babel-preset-expo": "~12.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "expo": "~52.0.20",
    "expo-asset": "~11.0.5",
    "expo-constants": "~17.0.3",
    "expo-linking": "~7.0.3",
    "expo-router": "~4.0.13",
    "expo-secure-store": "~14.0.1",
    "expo-status-bar": "~2.0.0",
    "nativewind": "^4.1.23",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hook-form": "^7.54.0",
    "react-native": "0.76.9",
    "react-native-css-interop": "^0.2.3",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "~0.19.13",
    "react-native-worklets": "~0.4.0",
    "tailwind-merge": "^2.5.5",
    "tailwindcss": "^3.4.17",
    "web-vitals": "^4.2.4",
    "zod": "^3.23.8",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@biomejs/biome": "^1.9.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16",
    "@testing-library/user-event": "^14",
    "@types/react": "~18.3.12",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "jsdom": "^25.0.1",
    "msw": "^2.7.0",
    "typescript": "~5.6.3",
    "vitest": "^2.1.8"
  }
}
