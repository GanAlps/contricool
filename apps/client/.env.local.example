# Phase 2d client envvars (only one needed at MVP).
#
# Point at the dev CloudFront distribution's /v1 prefix.
# Pull the host from the CloudFormation outputs of Contricool-Dev-Web
# stack (DistributionDomainName) — see specs/runbooks/first-deploy.md.
#
# Example value (DO NOT COMMIT THE REAL DEV DOMAIN):
#   EXPO_PUBLIC_API_BASE_URL=https://d-XXXXXXXXX.cloudfront.net/v1
#
# Or for same-origin same-host setups (e.g. local Caddy proxy):
#   EXPO_PUBLIC_API_BASE_URL=/v1
EXPO_PUBLIC_API_BASE_URL=
