# EAS local builds + React Native + babel-preset-expo + nativewind need
# a flat node_modules layout. Without this, pnpm's strict layout puts
# transitive deps in `.pnpm/<hash>/...` paths that Babel/Metro can't
# resolve at build time (the rabbit hole hits `babel-preset-expo`,
# `react-native-worklets/plugin`, `@babel/plugin-transform-react-jsx`,
# `expo-asset`, ... in turn).
#
# `node-linker=hoisted` makes pnpm produce an npm-style flat
# node_modules tree. We accept the trade-off: phantom deps work, the
# tree is bigger on disk. The strictness loss is acceptable since
# - apps/api is Python (no node_modules)
# - packages/client-sdk has a small dep set we control directly
# - apps/client is the only consumer that needs this anyway
node-linker=hoisted
